{
  "rewrites": [
    {
      "source": "/radares/:path*",
      "destination": "/radar/radares/:path*"
    },
    {
      "source": "/radar/:path*",
      "destination": "/radar/:path*"
    },
    {
      "source": "/style.css",
      "destination": "/radar/style.css"
    },
    {
      "source": "/feedback",
      "destination": "/feedback/index.html"
    },
    {
      "source": "/feedback/",
      "destination": "/feedback/index.html"
    },
    {
      "source": "/lista-de-espera",
      "destination": "/lista-de-espera/index.html"
    },
    {
      "source": "/lista-de-espera/",
      "destination": "/lista-de-espera/index.html"
    },
    {
      "source": "/apresentacao_comercial",
      "destination": "/apresentacao_comercial/index.html"
    },
    {
      "source": "/apresentacao_comercial/",
      "destination": "/apresentacao_comercial/index.html"
    },
    {
      "source": "/cadastro",
      "destination": "/formulario-cadastral/index.html"
    },
    {
      "source": "/cadastro/",
      "destination": "/formulario-cadastral/index.html"
    },
    {
      "source": "/radar/radares/:path*/style.css",
      "destination": "/radar/style.css"
    }
  ]
}
